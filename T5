        // Nieuwe handleFormSubmit met Supabase insert
        async function handleFormSubmit(e) {
            e.preventDefault();
            const name = document.getElementById('customer-name').value;
            const email = document.getElementById('customer-email').value;
            const phone = document.getElementById('customer-phone').value;
            if (!name || !email || !phone) {
                alert(currentLang === 'nl' ? 'Vul alle verplichte velden in.' : (currentLang === 'fr' ? 'Remplissez tous les champs.' : 'Fill in all fields.'));
                return;
            }
            if (!selectedVehicle) {
                alert(currentLang === 'nl' ? 'Selecteer een voertuig.' : (currentLang === 'fr' ? 'Sélectionnez un véhicule.' : 'Select a vehicle.'));
                goToStep(2);
                return;
            }
            if (!pickupMarker || !destinationMarker) {
                alert(currentLang === 'nl' ? 'Selecteer een geldige ophaal- en bestemmingslocatie.' : (currentLang === 'fr' ? 'Sélectionnez des adresses valides.' : 'Select valid addresses.'));
                return;
            }
            const bookingData = collectBookingData();
            if (supabaseClient) {
                try {
                    const { error } = await supabaseClient.from('bookings').insert([bookingData]);
                    if (error) throw error;
                    showThankYou();
                    // Na popup sluiten -> toon fiche
                    const thankBtn = document.querySelector('#thankyou-modal button');
                    const oldClick = thankBtn.onclick;
                    thankBtn.onclick = () => {
                        closeThankYou();
                        showBookingFiche(bookingData);
                        thankBtn.onclick = oldClick;
                    };
                } catch(err) {
                    console.error(err);
                    alert(currentLang === 'nl' ? 'Fout bij opslaan. Probeer later opnieuw.' : (currentLang === 'fr' ? 'Erreur. Réessayez.' : 'Error saving. Try again.'));
