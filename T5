<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>T5 - Fleet Airport Transfer (Supabase integrated)</title>
    <!-- Google Fonts: Inter & Playfair Display -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
    <!-- Leaflet JS -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <!-- Supabase SDK -->
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: { primary: '#0369a1', sky: '#e0f2fe' },
                    fontFamily: { sans: ['Inter', 'sans-serif'] }
                }
            }
        }
    </script>
    <style>
        .glass-card { background: rgba(255,255,255,0.9); backdrop-filter: blur(12px); border-radius: 24px; }
        .step-indicator.active { background-color: #0369a1; color: white; border-color: #0369a1; }
        #map { height: 400px; border-radius: 24px; }
        .vehicle-card.selected { border-color: #0369a1; background-color: #f0f9ff; }
        input, select, textarea { border-radius: 12px !important; border: 1px solid #bae6fd !important; }
        .airport-badge { background-color: #e0f2fe; color: #0369a1; padding: 4px 12px; border-radius: 99px; font-size: 10px; font-weight: 700; text-transform: uppercase; }
        /* Thank you popup */
        .thankyou-modal { position: fixed; inset: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 200; backdrop-filter: blur(4px); }
        .thankyou-card { background: white; max-width: 450px; width: 90%; border-radius: 32px; padding: 32px 24px; text-align: center; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25); animation: fadeIn 0.3s ease-out; border-top: 6px solid #0369a1; }
        @keyframes fadeIn { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }
        .thankyou-icon { width: 72px; height: 72px; background: #0369a1; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; font-size: 2.5rem; color: white; }
        .thankyou-card h2 { font-size: 1.5rem; font-weight: 800; color: #0369a1; margin-bottom: 0.5rem; }
        .thankyou-card p { color: #4b5563; margin-bottom: 1.5rem; }
        .thankyou-card button { background: #0369a1; color: white; border: none; padding: 10px 24px; border-radius: 40px; font-weight: 600; cursor: pointer; transition: opacity 0.2s; }
        .thankyou-card button:hover { opacity: 0.8; }
    </style>
</head>
<body class="bg-sky/30 text-slate-800 font-sans">

    <!-- HEADER (zelfde als origineel) -->
    <header id="main-header" class="bg-white/80 backdrop-blur-md border-b border-sky sticky top-0 z-50">
        <nav class="container mx-auto px-6 py-4 flex justify-between items-center">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-primary flex items-center justify-center text-white rounded-xl shadow-lg shadow-primary/20">
                    <i class="fas fa-plane-departure"></i>
                </div>
                <span class="text-xl font-bold text-primary tracking-tight uppercase">Fleetconnect</span>
            </div>
            <div class="hidden md:flex items-center gap-8 text-sm font-semibold text-slate-600">
                <a href="#hero" class="hover:text-primary transition">Home</a>
                <a href="#booking-section" class="hover:text-primary transition">Transfer Boeken</a>
                <a href="#services" class="hover:text-primary transition">Info</a>
            </div>
            <div class="flex items-center gap-4">
                <div class="flex bg-slate-100 p-1 rounded-lg">
                    <button onclick="setLanguage('nl')" class="px-2 py-1 text-[10px] font-bold rounded hover:bg-white transition">NL</button>
                    <button onclick="setLanguage('fr')" class="px-2 py-1 text-[10px] font-bold rounded hover:bg-white transition">FR</button>
                    <button onclick="setLanguage('en')" class="px-2 py-1 text-[10px] font-bold rounded hover:bg-white transition">EN</button>
                </div>
            </div>
        </nav>
    </header>

    <main>
        <!-- HERO + BOOKING SECTIE (origineel, maar include map and form) -->
        <section id="hero" class="relative py-24 overflow-hidden">
            <div class="container mx-auto px-6 flex flex-col items-center text-center relative z-10">
                <h1 class="text-5xl font-black text-slate-900 mb-6" data-i18n="hero_title">Airport Transfer</h1>
                <p class="text-slate-500 max-w-xl mb-8" data-i18n="hero_subtitle">Zorgeloos van en naar de luchthaven. Kies uw bestemming en begin uw reis in alle comfort.</p>
                <div class="flex justify-center gap-10 mb-12">
                    <div class="text-left"><span id="bookings-count" class="block text-2xl font-black text-primary">50+</span><span class="text-[10px] font-bold uppercase tracking-widest text-slate-400" data-i18n="monitoring_bookings">Transfers vandaag</span></div>
                    <div class="text-left"><span id="vehicles-count" class="block text-2xl font-black text-primary">18</span><span class="text-[10px] font-bold uppercase tracking-widest text-slate-400" data-i18n="monitoring_vehicles">Beschikbaar</span></div>
                </div>
                <div class="w-full max-w-4xl bg-white p-4 rounded-3xl shadow-2xl shadow-primary/10 flex flex-col md:flex-row gap-4">
                    <select id="hero-airport-select" class="flex-grow p-4 bg-slate-50 border-none outline-none text-slate-600 font-medium">
                        <option value="">Selecteer luchthaven...</option>
                        <option value="Brussel-Zaventem">Brussel-Zaventem (BRU)</option>
                        <option value="Charleroi Airport">Charleroi (CRL)</option>
                        <option value="Antwerpen Airport">Antwerpen (ANR)</option>
                        <option value="Luik Airport">Luik (LGG)</option>
                        <option value="Oostende Airport">Oostende (OST)</option>
                    </select>
                    <button onclick="selectAirportAndScroll()" class="bg-primary text-white px-10 py-4 rounded-2xl font-bold hover:opacity-90 transition">Plan Transfer</button>
                </div>
            </div>
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-primary/5 rounded-full blur-[120px] -z-10"></div>
        </section>

        <section id="booking-section" class="py-20">
            <div class="container mx-auto px-6">
                <div class="max-w-6xl mx-auto flex flex-col lg:flex-row gap-12">
                    <!-- Kaart Links -->
                    <div class="lg:w-1/2">
                        <div class="sticky top-32">
                            <div class="flex items-center gap-3 mb-8"><span class="airport-badge">Live Route</span><h2 class="text-2xl font-bold text-slate-900 uppercase tracking-tight" data-i18n="step1_title">Route</h2></div>
                            <div id="map" class="shadow-xl shadow-primary/5 border border-sky"></div>
                            <div class="mt-8 p-8 bg-white rounded-3xl border border-sky flex justify-between items-center shadow-sm"><div><p class="text-[10px] font-black text-slate-400 uppercase mb-1" data-i18n="total_price_label">Vaste Prijs</p><p class="text-4xl font-bold text-primary" id="display-price">€ 0.00</p></div><div class="text-right text-slate-400 text-xs font-bold" id="route-info">0 km | 0 min</div></div>
                        </div>
                    </div>
                    <!-- Formulier Rechts -->
                    <div class="lg:w-1/2 glass-card p-8 md:p-12 shadow-2xl border border-white">
                        <div class="flex justify-between mb-16 relative"><div class="absolute top-1/2 left-0 w-full h-1 bg-sky -translate-y-1/2"></div><div class="step-indicator active w-12 h-12 rounded-full flex items-center justify-center font-bold z-10 relative bg-white border-4 border-sky transition shadow-sm" id="step-1-indicator">1</div><div class="step-indicator w-12 h-12 rounded-full flex items-center justify-center font-bold z-10 relative bg-white border-4 border-sky transition shadow-sm" id="step-2-indicator">2</div><div class="step-indicator w-12 h-12 rounded-full flex items-center justify-center font-bold z-10 relative bg-white border-4 border-sky transition shadow-sm" id="step-3-indicator">3</div><div class="step-indicator w-12 h-12 rounded-full flex items-center justify-center font-bold z-10 relative bg-white border-4 border-sky transition shadow-sm" id="step-4-indicator">4</div></div>
                        <form id="booking-form" onsubmit="return handleFormSubmit(event)">
                            <!-- STAP 1 -->
                            <div id="step-1" class="space-y-6">
                                <div class="relative"><label class="block text-xs font-bold text-slate-500 uppercase mb-3">Van (Ophalen)</label><input type="text" id="pickup" required class="w-full px-5 py-4" placeholder="bijv. Uw adres of hotel" oninput="searchAddress(this.value, 'pickup')"><div id="pickup-results" class="absolute z-50 w-full bg-white border border-sky shadow-2xl mt-1 hidden text-sm"></div></div>
                                <div class="relative"><label class="block text-xs font-bold text-slate-500 uppercase mb-3">Naar (Luchthaven)</label><select id="destination" required class="w-full px-5 py-4" onchange="searchAddress(this.value, 'destination', true)"><option value="">Selecteer luchthaven...</option><option value="Brussels Airport">Brussel-Zaventem (BRU)</option><option value="Brussels South Charleroi Airport">Charleroi (CRL)</option><option value="Antwerp International Airport">Antwerpen (ANR)</option><option value="Liège Airport">Luik (LGG)</option><option value="Ostend-Bruges International Airport">Oostende (OST)</option></select></div>
                                <div class="grid grid-cols-2 gap-6"><div><label class="block text-xs font-bold text-slate-500 uppercase mb-3" data-i18n="label_date">Datum</label><input type="date" id="booking-date" required class="w-full px-5 py-4" onchange="validateStep1()"></div><div><label class="block text-xs font-bold text-slate-500 uppercase mb-3" data-i18n="label_time">Tijd</label><input type="time" id="booking-time" required class="w-full px-5 py-4" onchange="validateStep1()"></div></div>
                                <div class="flex items-center gap-3 p-4 bg-sky/20 rounded-2xl border border-sky"><input type="checkbox" id="return-trip" class="w-5 h-5 accent-primary" onchange="updatePrice()"><label for="return-trip" class="text-xs font-bold text-slate-500 uppercase cursor-pointer" data-i18n="return_trip">Retourtje</label></div>
                                <div><label class="block text-xs font-bold text-slate-500 uppercase mb-3" data-i18n="payment_label">Betaalmethode</label><div class="grid grid-cols-3 gap-3"><label class="cursor-pointer group"><input type="radio" name="payment-method-step1" value="cash" class="hidden" checked onchange="syncPayment(this.value)"><div class="p-4 border border-sky rounded-2xl text-center text-[10px] font-bold uppercase transition group-hover:bg-sky/50">Cash</div></label><label class="cursor-pointer group"><input type="radio" name="payment-method-step1" value="card" class="hidden" onchange="syncPayment(this.value)"><div class="p-4 border border-sky rounded-2xl text-center text-[10px] font-bold uppercase transition group-hover:bg-sky/50">Kaart</div></label><label class="cursor-pointer group"><input type="radio" name="payment-method-step1" value="online" class="hidden" onchange="syncPayment(this.value)"><div class="p-4 border border-sky rounded-2xl text-center text-[10px] font-bold uppercase transition group-hover:bg-sky/50">Online</div></label></div></div>
                                <button type="button" id="btn-step-1-next" onclick="goToStep(2)" class="w-full bg-primary text-white py-5 rounded-2xl font-bold uppercase tracking-widest shadow-xl shadow-primary/20 transition hover:opacity-90 disabled:opacity-30 disabled:cursor-not-allowed" data-i18n="btn_next" disabled>Kies Voertuig</button>
                            </div>
                            <!-- STAP 2 -->
                            <div id="step-2" class="hidden space-y-6"><h3 class="font-bold text-primary uppercase mb-6" data-i18n="step2_title">Luchthaven Vloot</h3><div id="vehicle-list" class="space-y-4"></div><div class="flex gap-4"><button type="button" onclick="goToStep(1)" class="w-1/3 border border-sky py-5 rounded-2xl font-bold uppercase text-xs" data-i18n="btn_prev">Terug</button><button type="button" onclick="goToStep(3)" class="w-2/3 bg-primary text-white py-5 rounded-2xl font-bold uppercase tracking-widest transition" data-i18n="btn_next">Volgende</button></div></div>
                            <!-- STAP 3 -->
                            <div id="step-3" class="hidden space-y-6"><h3 class="font-bold text-primary uppercase mb-6" data-i18n="step3_title">Extra Opties</h3><div class="space-y-4"><div class="grid grid-cols-2 gap-4"><div class="p-4 bg-sky/20 rounded-2xl"><label class="block text-[10px] font-bold uppercase text-primary mb-2">Vluchtnummer</label><input type="text" id="flight-number" class="w-full bg-white border-none p-2 text-sm" placeholder="bijv. SN1234"></div><div class="p-4 bg-sky/20 rounded-2xl"><label class="block text-[10px] font-bold uppercase text-primary mb-2" data-i18n="label_baggage">Bagage</label><select id="baggage-count" class="w-full bg-white border-none p-2 text-sm"><option value="1">1 piece</option><option value="2">2 pieces</option><option value="3">3 pieces</option><option value="4">4 pieces</option><option value="5">5+ pieces</option></select></div></div><div class="p-4 bg-sky/20 rounded-2xl"><label class="block text-[10px] font-bold uppercase text-primary mb-2">Wachttijd</label><select id="waiting-time" class="w-full bg-white border-none p-2 text-sm"><option value="15">15 min</option><option value="30">30 min (Standard)</option><option value="45">45 min</option><option value="60">60 min</option></select></div><div class="flex items-center justify-between p-4 bg-sky/20 rounded-2xl"><span class="text-xs font-bold uppercase" data-i18n="child_seat_label">Kinderstoeltje (+€5)</span><input type="number" id="extra-child-seat" value="0" min="0" max="3" class="w-16 text-center border-none bg-white py-1" onchange="updatePrice()"></div><div class="flex items-center justify-between p-4 bg-sky/20 rounded-2xl"><span class="text-xs font-bold uppercase" data-i18n="wifi_label">WiFi (+€5)</span><input type="checkbox" id="extra-wifi" class="w-5 h-5 accent-primary" onchange="updatePrice()"></div></div><div class="flex gap-4"><button type="button" onclick="goToStep(2)" class="w-1/3 border border-sky py-5 rounded-2xl font-bold uppercase text-xs" data-i18n="btn_prev">Terug</button><button type="button" onclick="goToStep(4)" class="w-2/3 bg-primary text-white py-5 rounded-2xl font-bold uppercase tracking-widest transition" data-i18n="btn_next">Laatste stap</button></div></div>
                            <!-- STAP 4 -->
                            <div id="step-4" class="hidden space-y-6"><h3 class="font-bold text-primary uppercase mb-6" data-i18n="step4_title">Persoonsgegevens</h3><div class="space-y-4"><input type="text" id="customer-name" required class="w-full px-5 py-4" placeholder="Uw Naam"><input type="email" id="customer-email" required class="w-full px-5 py-4" placeholder="Email"><input type="tel" id="customer-phone" required class="w-full px-5 py-4" placeholder="Telefoon"><div class="pt-4"><label class="block text-xs font-bold text-slate-500 uppercase mb-3" data-i18n="payment_label">Betaalmethode</label><div class="grid grid-cols-3 gap-3"><label class="cursor-pointer group"><input type="radio" name="payment-method" value="cash" class="hidden" checked onchange="syncPayment(this.value)"><div class="p-4 border border-sky rounded-2xl text-center text-[10px] font-bold uppercase transition group-hover:bg-sky/50">Cash</div></label><label class="cursor-pointer group"><input type="radio" name="payment-method" value="card" class="hidden" onchange="syncPayment(this.value)"><div class="p-4 border border-sky rounded-2xl text-center text-[10px] font-bold uppercase transition group-hover:bg-sky/50">Kaart</div></label><label class="cursor-pointer group"><input type="radio" name="payment-method" value="online" class="hidden" onchange="syncPayment(this.value)"><div class="p-4 border border-sky rounded-2xl text-center text-[10px] font-bold uppercase transition group-hover:bg-sky/50">Online</div></label></div></div></div><div class="flex gap-4 pt-6"><button type="button" onclick="goToStep(3)" class="w-1/3 border border-sky py-5 rounded-2xl font-bold uppercase text-xs" data-i18n="btn_prev">Terug</button><button type="submit" class="w-2/3 bg-primary text-white py-5 rounded-2xl font-bold uppercase tracking-widest transition shadow-xl shadow-primary/20" data-i18n="btn_submit">Bevestigen</button></div></div>
                        </form>
                    </div>
                </div>
            </div>
        </section>

        <!-- Overige secties (shuttle, group, services, contact, footer) zijn identiek aan origineel, maar voor lengte weglaten? We moeten ze includen voor compleetheid. Gebruik originele code hier -->
        <section class="py-20 bg-sky/20"><div class="container mx-auto px-6"><div class="grid md:grid-cols-2 gap-12"><div class="p-10 bg-white rounded-[32px] border border-sky flex items-center gap-8 shadow-sm"><div class="w-16 h-16 bg-sky rounded-2xl flex items-center justify-center text-primary shrink-0"><i class="fas fa-shuttle-van text-2xl"></i></div><div><h3 class="text-lg font-bold text-slate-900 mb-1" data-i18n="shuttle_title">Shuttle Service</h3><p class="text-sm text-slate-500" data-i18n="shuttle_desc">Luchthavens, stations, hotels – exclusief en punctueel</p></div></div><div class="p-10 bg-white rounded-[32px] border border-sky flex items-center gap-8 shadow-sm"><div class="w-16 h-16 bg-sky rounded-2xl flex items-center justify-center text-primary shrink-0"><i class="fas fa-users text-2xl"></i></div><div><h3 class="text-lg font-bold text-slate-900 mb-1" data-i18n="group_title">Groepsvervoer</h3><p class="text-sm text-slate-500" data-i18n="group_desc">Minibus (8 pers) | Autocar (20-50 pers) – voor grote gezelschappen</p></div></div></div></div></section>
        <section id="contact" class="py-24 bg-slate-900 text-white"><div class="container mx-auto px-6"><div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-16 items-center"><div><h2 class="text-3xl font-black mb-8 uppercase tracking-tight" data-i18n="contact_title">Airport Contact</h2><p class="text-slate-400 mb-8 italic">Vragen over uw vlucht of onze service?</p><div class="space-y-4"><div class="flex items-center gap-4"><i class="fas fa-phone text-primary"></i><span class="font-bold">+32 000 00 00 00</span></div><div class="flex items-center gap-4"><i class="fas fa-envelope text-primary"></i><span class="font-bold">airport@fleetconnect.be</span></div></div></div><form onsubmit="event.preventDefault(); alert('Message sent!');" class="space-y-4"><input type="text" placeholder="Naam" required class="w-full px-5 py-4 bg-slate-800 border-none text-white rounded-2xl"><input type="email" placeholder="Email" required class="w-full px-5 py-4 bg-slate-800 border-none text-white rounded-2xl"><textarea placeholder="Uw bericht" rows="4" required class="w-full px-5 py-4 bg-slate-800 border-none text-white rounded-2xl"></textarea><button type="submit" class="w-full bg-primary text-white py-5 rounded-2xl font-bold uppercase tracking-widest" data-i18n="contact_send">Verstuur</button></form></div></div></section>
        <section id="services" class="py-24 bg-white"><div class="container mx-auto px-6"><div class="grid md:grid-cols-2 gap-16"><div><h2 class="text-3xl font-black text-slate-900 mb-8 uppercase tracking-tight" data-i18n="services_title">Airport Service</h2><div class="space-y-6"><div class="flex gap-4"><div class="w-12 h-12 bg-sky rounded-xl flex items-center justify-center shrink-0"><i class="fas fa-clock text-primary"></i></div><div><h4 class="font-bold mb-1" data-i18n="info_waiting_title">60 Minuten Wachttijd</h4><p class="text-sm text-slate-500" data-i18n="info_waiting_desc">Gratis wachttijd na landing voor al onze luchthaventransfers.</p></div></div><div class="flex gap-4"><div class="w-12 h-12 bg-sky rounded-xl flex items-center justify-center shrink-0"><i class="fas fa-calendar-times text-primary"></i></div><div><h4 class="font-bold mb-1" data-i18n="info_cancel_title">Gratis Annuleren</h4><p class="text-sm text-slate-500" data-i18n="info_cancel_desc">Tot 24 uur voor vertrek kosteloos annuleren van uw rit.</p></div></div><div class="flex gap-4"><div class="w-12 h-12 bg-sky rounded-xl flex items-center justify-center shrink-0"><i class="fas fa-suitcase text-primary"></i></div><div><h4 class="font-bold mb-1" data-i18n="service3_title">Bagage Service</h4><p class="text-sm text-slate-500">Hulp bij uw bagage is standaard inbegrepen.</p></div></div><div class="flex gap-4"><div class="w-12 h-12 bg-sky rounded-xl flex items-center justify-center shrink-0"><i class="fas fa-headset text-primary"></i></div><div><h4 class="font-bold mb-1" data-i18n="service4_title">24/7 Monitoring</h4><p class="text-sm text-slate-500">Wij volgen uw vlucht live op eventuele vertragingen.</p></div></div></div></div><div id="about" class="bg-slate-50 p-10 rounded-[40px]"><h3 class="font-bold text-xl mb-6">Belangrijke Informatie</h3><ul class="space-y-4 text-sm text-slate-500"><li class="flex items-start gap-3"><i class="fas fa-info-circle text-primary mt-1"></i><span>Chauffeur wacht bij de aankomsthal met een naambordje.</span></li><li class="flex items-start gap-3"><i class="fas fa-info-circle text-primary mt-1"></i><span>Vluchten worden live gevolgd op eventuele vertragingen.</span></li><li class="flex items-start gap-3"><i class="fas fa-info-circle text-primary mt-1"></i><span>Hulp bij bagage is altijd inbegrepen in de service.</span></li></ul></div></div></div></section>
    </main>

    <!-- BOEKING FICHE MODAL (origineel, maar we moeten de weergave aanpassen aan admin velden) -->
    <div id="booking-fiche-modal" class="fixed inset-0 z-[100] hidden items-center justify-center bg-slate-900/95 backdrop-blur-sm p-4">
        <div class="bg-white w-full max-w-2xl rounded-3xl overflow-hidden shadow-2xl flex flex-col max-h-[90vh] border border-sky">
            <div class="p-6 border-b border-sky/30 flex justify-between items-center bg-sky/10"><div class="flex items-center gap-3"><div class="w-10 h-10 bg-primary text-white rounded-full flex items-center justify-center shadow-lg"><i class="fas fa-plane-arrival"></i></div><div><h2 class="text-slate-900 font-bold uppercase tracking-tight" data-i18n="fiche_title">Airport Transfer Confirmation</h2><p class="text-[10px] text-primary font-bold uppercase tracking-widest" data-i18n="fiche_subtitle">Safe & On-Time Arrival</p></div></div><button onclick="closeFiche()" class="text-slate-400 hover:text-primary transition"><i class="fas fa-times text-xl"></i></button></div>
            <div id="fiche-content" class="p-8 overflow-y-auto bg-white text-slate-800"></div>
            <div class="p-6 border-t border-sky/30 bg-sky/5 flex flex-wrap gap-4 justify-between items-center"><div class="flex gap-4"><button onclick="printFiche()" class="flex items-center gap-2 px-5 py-3 bg-white border border-sky/50 text-slate-700 rounded-xl hover:bg-sky/10 transition text-xs font-bold uppercase tracking-widest"><i class="fas fa-print text-primary"></i> <span data-i18n="btn_print">Print</span></button><button onclick="saveFicheAsJSON()" class="flex items-center gap-2 px-5 py-3 bg-white border border-sky/50 text-slate-700 rounded-xl hover:bg-sky/10 transition text-xs font-bold uppercase tracking-widest"><i class="fas fa-download text-primary"></i> <span data-i18n="btn_download">JSON</span></button></div><button onclick="location.reload()" class="px-8 py-3 bg-primary text-white rounded-xl font-bold hover:shadow-xl hover:shadow-primary/20 transition uppercase tracking-widest text-xs"><span data-i18n="btn_close">Close</span></button></div>
        </div>
    </div>

    <!-- DANKJEWEL POPUP -->
