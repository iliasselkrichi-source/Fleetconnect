    <div class="main">
        <div class="header">
            <h1 id="pageTitle">Agenda</h1>
            <div class="download-buttons hidden" id="downloadButtons">
                <button class="download-btn" onclick="downloadCSV()"><i class="fas fa-file-csv"></i> CSV</button>
                <button class="download-btn" onclick="downloadJSON()"><i class="fas fa-code"></i> JSON</button>
