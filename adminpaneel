        async function resetToDemoData() {
            if (confirm("Reset alle data naar demo? Dit overschrijft ook Supabase.")) {
                rawNewOrders = getDefaultNewOrders();
                rawConfirmedOrders = getDefaultConfirmedOrders();
                driversList = getDefaultDrivers();
                onderaannemersList = getDefaultSubcontractors();
                onderaannemersList.forEach(oa => oa.drivers = driversList.filter(d => d.onderaannemer_id === oa.id));
                await persistAll();
                await loadAllData();
                if (currentTab === 'agenda') refreshAgenda();
                else if (currentTab === 'neworders') renderNewOrders();
                else if (currentTab === 'orders') renderOrders();
                else if (currentTab === 'history') renderHistory();
                else if (currentTab === 'drivers') renderDrivers();
