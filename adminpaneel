        function downloadCSV() { /* zelfde als eerder */ const headers = ["ID","Template","Datum","Tijd","Klant","Email","Telefoon","Pickup","Destination","Voertuig","Extras","Bedrag","Betaling","Status"]; const rows = historyOrders.map(o => [o.id, o.template, o.datetime, o.time, o.name, o.email, o.phone, o.pickup, o.destination, o.vehicle, o.extras, o.amount, o.payment, o.completed?"Uitgevoerd":(o.canceled?"Geannuleerd":"Bevestigd")]); const csv = [headers, ...rows].map(r => r.map(c => `"${c}"`).join(",")).join("\n"); const blob = new Blob(["\uFEFF"+csv], {type:"text/csv"}); const a = document.createElement('a'); a.href=URL.createObjectURL(blob); a.download=`fleet_history_${new Date().toISOString().slice(0,19)}.csv`; a.click(); }
        function downloadJSON() { const blob = new Blob([JSON.stringify(historyOrders,null,2)], {type:"application/json"}); const a = document.createElement('a'); a.href=URL.createObjectURL(blob); a.download=`fleet_history_${new Date().toISOString().slice(0,19)}.json`; a.click(); }

