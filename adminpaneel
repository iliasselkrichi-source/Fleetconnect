        <div class="content" id="contentArea"><div class="loading"><i class="fas fa-spinner fa-pulse"></i> Gegevens laden uit Supabase...</div></div>
    </div>

    <div id="bookingModal" class="modal"><div class="modal-content"><div class="fiche-header"><h3><i class="fas fa-file-invoice"></i> Boekingsfiche</h3><button class="close-modal" onclick="closeModal()">&times;</button></div><div class="fiche-body" id="ficheBody"></div></div></div>

    <script>
        // ==================== SUPABASE CONFIG ====================
        const SUPABASE_URL = 'https://kwsuqzbqzsmgkjaslwkz.supabase.co';
        const SUPABASE_ANON_KEY = 'sb_publishable_5hdl73a9-jNd9n3lnsYVyQ_dMYgiSLA';
        let supabase = null;
        let useSupabase = true;  // valt terug naar localStorage bij fouten

        // ==================== GLOBALE DATA (in-memory cache) ====================
        let rawNewOrders = [];      // status = 'pending'
        let rawConfirmedOrders = []; // status = 'confirmed'
        let driversList = [];
        let onderaannemersList = [];
        let allRides = [];
        let selectedDate = null, currentMonth = null, isFlipped = false;
        let flipStates = { omzet: false, cash: false, orders: false };
        let newOrders = [], ordersList = [], historyOrders = [];
        let currentTab = 'agenda';
        let currentSelectedOrder = null, selectedDriverId = null;
        let financePeriod = 'month', customStartDate = null, customEndDate = null, financeChart = null;

        // ==================== HULPFUNCTIES ====================
        function getCurrentNOW() { return new Date(); }
        function parseDateTime(dateStr, timeStr) {
            const parts = dateStr.split('-');
            const timeParts = timeStr ? timeStr.split(':') : ['00','00'];
            return new Date(parseInt(parts[2]), parseInt(parts[1])-1, parseInt(parts[0]), parseInt(timeParts[0]), parseInt(timeParts[1]));
        }
        function isOrderInFuture(order) {
            return parseDateTime(order.datetime, order.time) > getCurrentNOW();
        }
        function updateAgendaData() {
            allRides = rawConfirmedOrders.map(order => ({
                id: order.id, date: order.datetime, time: order.time, name: order.name,
                pickup: order.pickup, destination: order.destination, vehicle: order.vehicle,
                driver: order.assignedDriver, amount: order.amount, template: order.template,
                completed: order.completed || false, canceled: order.canceled || false, payment: order.payment
            }));
        }
        function filterAndSortData() {
            const now = getCurrentNOW();
            newOrders = rawNewOrders.filter(o => isOrderInFuture(o));
            ordersList = [];
            historyOrders = [];
            rawConfirmedOrders.forEach(order => {
                if (isOrderInFuture(order)) ordersList.push({...order});
                else historyOrders.push({...order});
            });
            ordersList.sort((a,b) => parseDateTime(a.datetime, a.time) - parseDateTime(b.datetime, b.time));
            historyOrders.sort((a,b) => parseDateTime(b.datetime, b.time) - parseDateTime(a.datetime, a.time));
        }

        // ==================== SUPABASE CRUD ====================
        async function loadAllFromSupabase() {
            if (!supabase) return false;
            try {
                // Laad alle boekingen
                const { data: bookings, error: bErr } = await supabase.from('bookings').select('*');
                if (bErr) throw bErr;
                const { data: drivers, error: dErr } = await supabase.from('drivers').select('*');
                if (dErr) throw dErr;
                const { data: subs, error: sErr } = await supabase.from('subcontractors').select('*');
                if (sErr) throw sErr;

                rawNewOrders = bookings.filter(b => b.status === 'pending');
                rawConfirmedOrders = bookings.filter(b => b.status === 'confirmed');
                driversList = drivers || [];
                onderaannemersList = (subs || []).map(s => ({ ...s, drivers: driversList.filter(d => d.onderaannemer_id === s.id) }));
                return true;
            } catch(e) {
                console.warn('Supabase load error, falling back to localStorage', e);
                return false;
            }
        }

        async function saveBookingToSupabase(booking, isNew = false) {
            if (!supabase) return false;
            try {
                if (isNew) {
                    const { error } = await supabase.from('bookings').insert([booking]);
                    if (error) throw error;
                } else {
                    const { error } = await supabase.from('bookings').update(booking).eq('id', booking.id);
                    if (error) throw error;
                }
                return true;
            } catch(e) { console.error('Supabase save error', e); return false; }
        }

        async function deleteBookingFromSupabase(bookingId) {
            if (!supabase) return false;
            try {
                const { error } = await supabase.from('bookings').delete().eq('id', bookingId);
                if (error) throw error;
                return true;
            } catch(e) { return false; }
        }

        async function saveDriverToSupabase(driver, isNew = false) {
            if (!supabase) return false;
            try {
                if (isNew) await supabase.from('drivers').insert([driver]);
                else await supabase.from('drivers').update(driver).eq('id', driver.id);
                return true;
            } catch(e) { return false; }
        }

        async function saveSubcontractorToSupabase(sub, isNew = false) {
            if (!supabase) return false;
            try {
                if (isNew) await supabase.from('subcontractors').insert([sub]);
                else await supabase.from('subcontractors').update(sub).eq('id', sub.id);
                return true;
            } catch(e) { return false; }
        }

        async function deleteSubcontractorFromSupabase(id) {
            if (!supabase) return false;
            try {
                await supabase.from('subcontractors').delete().eq('id', id);
                return true;
            } catch(e) { return false; }
        }

        // ==================== PERSISTENTIE (Supabase eerst, fallback localStorage) ====================
        async function persistAll() {
            if (useSupabase && supabase) {
                // Voor elk gewijzigd item moeten we updates doen, maar we doen nu een bulk sync
                // Eenvoudig: alle huidige data naar Supabase sturen (upsert)
                for (let b of [...rawNewOrders, ...rawConfirmedOrders]) await saveBookingToSupabase(b);
                for (let d of driversList) await saveDriverToSupabase(d);
                for (let s of onderaannemersList) await saveSubcontractorToSupabase(s);
            } else {
                // Fallback naar localStorage
                localStorage.setItem('fleet_rawNewOrders', JSON.stringify(rawNewOrders));
                localStorage.setItem('fleet_rawConfirmedOrders', JSON.stringify(rawConfirmedOrders));
                localStorage.setItem('fleet_driversList', JSON.stringify(driversList));
                localStorage.setItem('fleet_onderaannemersList', JSON.stringify(onderaannemersList));
            }
        }

        async function loadAllData() {
            if (supabase) {
                const ok = await loadAllFromSupabase();
                if (!ok) {
                    useSupabase = false;
                    loadFromLocalStorageFallback();
                }
            } else {
                loadFromLocalStorageFallback();
            }
            // Zorg dat onderaannemer.drivers up-to-date is
            onderaannemersList.forEach(oa => {
