        // AANGEPAST: verzamel data in admin-formaat
        function collectBookingData() {
            const fullName = document.getElementById('customer-name').value;
            const nameParts = fullName.split(' ');
            const firstName = nameParts[0];
            const lastName = nameParts.slice(1).join(' ') || '-';
            const extrasList = [];
            const childSeats = parseInt(document.getElementById('extra-child-seat').value) || 0;
            if (childSeats) extrasList.push(`${childSeats}x Kinderstoel (€${childSeats*5})`);
            if (document.getElementById('extra-wifi').checked) extrasList.push('WiFi (€5)');
            const flight = document.getElementById('flight-number').value;
            if (flight) extrasList.push(`Vlucht: ${flight}`);
            const baggage = document.getElementById('baggage-count').value;
            extrasList.push(`Bagage: ${baggage} stuks`);
            const waiting = document.getElementById('waiting-time').value;
            extrasList.push(`Wachttijd: ${waiting} min`);
            const returnTrip = document.getElementById('return-trip').checked;
            const totalPrice = updatePrice();
            const paymentMethod = document.querySelector('input[name="payment-method"]:checked')?.value || 'cash';
            return {
                id: generateBookingNumber(),
                template: "T5",
                datetime: document.getElementById('booking-date').value,
                time: document.getElementById('booking-time').value,
                name: `${firstName} ${lastName}`,
                email: document.getElementById('customer-email').value,
                phone: document.getElementById('customer-phone').value,
                pickup: document.getElementById('pickup').value,
                destination: document.getElementById('destination').value,
                vehicle: selectedVehicle ? selectedVehicle.name : 'Onbekend',
                extras: extrasList.join(', '),
                amount: totalPrice,
